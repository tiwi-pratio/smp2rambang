# Railway Environment Variables
# Tambahkan semua ini di Railway Dashboard > Variables

# Otomatis diset Railway — jangan diisi manual
# PORT=3000

# Wajib diisi
NODE_ENV=production
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
PIO_API_KEY=your-pio-api-key
